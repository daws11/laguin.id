{
  "name": "valentine-projects",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,magenta,green \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:web\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w api",
    "dev:worker": "npm run dev:worker -w api",
    "start": "node apps/api/dist/index.js",
    "build": "npm run build --workspace=shared && npm run build --workspace=api && npm run build --workspace=web",
    "lint": "npm run lint -ws",
    "typecheck": "npm run typecheck -ws",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "pm2:start": "pm2 start infra/ecosystem.config.cjs",
    "pm2:reload": "pm2 reload infra/ecosystem.config.cjs",
    "pm2:stop": "pm2 stop infra/ecosystem.config.cjs",
    "pm2:delete": "pm2 delete infra/ecosystem.config.cjs",
    "pm2:logs": "pm2 logs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "shadcn": "^3.8.4"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@google-cloud/storage": "^7.19.0",
    "@replit/object-storage": "^1.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@uppy/aws-s3": "^5.1.0",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/react": "^5.2.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "google-auth-library": "^10.5.0",
    "nodemailer": "^8.0.1",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  }
}
