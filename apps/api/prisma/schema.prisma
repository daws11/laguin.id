generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PromptTemplateType {
  lyrics
  mood_description
  music
}

enum OrderStatus {
  created
  processing
  completed
  failed
}

enum DeliveryStatus {
  delivery_pending
  delivery_scheduled
  delivered
  delivery_failed
}

enum PaymentStatus {
  free
  pending
  paid
  failed
}

model Settings {
  id               String   @id @default(cuid())
  openaiApiKeyEnc  String?
  openaiModel      String?
  kaiAiApiKeyEnc   String?
  whatsappProvider String   @default("mock")
  whatsappConfig   Json?
  publicSiteConfig Json?
  instantEnabled   Boolean  @default(true)
  deliveryDelayHours Int?
  paymentsEnabled  Boolean  @default(false)
  emailOtpEnabled Boolean  @default(true)
  agreementEnabled Boolean @default(false)
  manualConfirmationEnabled Boolean @default(false)
  defaultThemeSlug String?
  showThemesInFooter Boolean @default(false)
  metaPixelId      String?
  metaPixelWishlistId String?
  metaPixelStep1Script String?
  metaPixelStep4Script String?
  metaPixelConfirmScript String?
  metaCapiEnabled  Boolean  @default(false)
  metaCapiAccessTokenEnc String?
  metaCapiTestEventCode  String?
  xenditSecretKeyEnc String?
  xenditWebhookToken String?
  allowMultipleOrdersPerWhatsapp Boolean @default(false)

  emailProvider      String   @default("smtp")
  smtpHost           String?
  smtpPort           Int?
  smtpSecure         Boolean  @default(false)
  smtpUser           String?
  smtpPassEnc        String?
  smtpFrom           String?
  resendApiKeyEnc    String?
  resendFrom         String?

  s3Endpoint         String?
  s3Bucket           String?
  s3AccessKeyEnc     String?
  s3SecretKeyEnc     String?
  s3Region           String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Theme {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  isActive       Boolean  @default(true)
  settings       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

model PromptTemplate {
  id           String             @id @default(cuid())
  type         PromptTemplateType
  templateText String
  kaiSettings  Json?
  version      Int
  isActive     Boolean            @default(false)
  createdAt    DateTime           @default(now())

  @@unique([type, version])
  @@index([type, isActive])
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  whatsappNumber String?  @unique
  email         String?
  // Normalized (trimmed + lowercased) email used for uniqueness checks.
  // NOTE: Existing legacy rows may keep `email` but have a synthetic `emailLower` suffix
  //       to satisfy uniqueness without breaking delivery for historical orders.
  emailLower    String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  verifiedAt DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, createdAt])
  @@index([expiresAt])
}

model Order {
  id                 String         @id @default(cuid())
  customerId         String
  customer           Customer       @relation(fields: [customerId], references: [id])

  inputPayload       Json
  themeSlug          String?

  status             OrderStatus    @default(created)
  deliveryStatus     DeliveryStatus @default(delivery_pending)
  paymentStatus      PaymentStatus  @default(free)

  lyricsText         String?
  moodDescription    String?
  trackUrl           String?
  trackMetadata      Json?

  confirmedAt        DateTime?
  generationStartedAt DateTime?
  generationCompletedAt DateTime?
  deliveryScheduledAt DateTime?
  deliveredAt        DateTime?

  errorMessage       String?

  xenditInvoiceId    String?
  xenditInvoiceUrl   String?

  discountCode       String?
  discountAmount     Int?

  upsellItems        Json?

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  regenerationCount  Int            @default(0)

  events             OrderEvent[]
  xenditWebhookLogs  XenditWebhookLog[]
  testimonialVideos  TestimonialVideo[]
  whatsAppLogs       WhatsAppLog[]

  @@index([status])
  @@index([deliveryStatus])
  @@index([customerId, createdAt])
  @@index([themeSlug])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String
  message   String?
  data      Json?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([type])
}

model XenditWebhookLog {
  id         String   @id @default(cuid())
  orderId    String?
  xenditId   String?
  status     String?
  amount     Float?
  payload    Json
  receivedAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])
}

model OrderDraft {
  id                  String   @id @default(cuid())
  draftKey            String   @unique

  step                Int      @default(0)
  relationship        String?
  formValues          Json
  themeSlug           String?

  emailLower          String?
  whatsappNumber      String?
  emailVerificationId String?
  convertedOrderId    String?
  whatsappCapturedAt  DateTime?
  remindersSent       Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  whatsAppLogs        WhatsAppLog[]

  @@index([updatedAt])
  @@index([emailLower])
  @@index([whatsappNumber])
  @@index([themeSlug])
  @@index([whatsappCapturedAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  sessionId String
  themeSlug String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
  @@index([themeSlug])
}

model TestimonialVideo {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  videoUrl  String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([status])
}

enum WhatsAppLogType {
  delivery_sent
  delivery_failed
  reminder_sent
  reminder_failed
}

model WhatsAppLog {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  type            WhatsAppLogType
  phone           String
  templateName    String
  templateLangCode String?
  orderId         String?
  order           Order?          @relation(fields: [orderId], references: [id])
  draftId         String?
  draft           OrderDraft?     @relation(fields: [draftId], references: [id])
  error           String?

  @@index([createdAt])
  @@index([type])
  @@index([orderId])
  @@index([draftId])
}

enum ExportJobStatus {
  pending
  done
  failed
}

model ExportJob {
  id        String          @id @default(cuid())
  type      String
  status    ExportJobStatus @default(pending)
  params    Json
  fileKey   String?
  error     String?
  createdAt DateTime        @default(now())
  expiresAt DateTime?

  @@index([status])
  @@index([createdAt])
}

enum DiscountCodeStatus {
  active
  paused
}

model DiscountCode {
  id              String             @id @default(cuid())
  code            String             @unique
  fixedAmount     Int
  templateSlugs   Json?
  startsAt        DateTime?
  endsAt          DateTime?
  maxUsesPerPhone Int?
  status          DiscountCodeStatus @default(active)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([code])
}
