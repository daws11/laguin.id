modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && npx concurrently -n api,worker,web -c blue,magenta,green \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:web\""
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd /home/runner/workspace/apps/api && npx prisma db push --skip-generate && PORT=5000 npx tsx src/index.ts"]
build = ["bash", "-c", "cd /home/runner/workspace && npm run build --workspace=shared && npm run build --workspace=web && cd apps/api && npx prisma generate"]

[userenv]

[userenv.development]
KIE_AI_CALLBACK_URL = "https://262c5f1e-18e0-4f63-8704-8343cc9f332c-00-3459vzkboxcdp.sisko.replit.dev/api/kie/callback"

[userenv.production]
KIE_AI_CALLBACK_URL = "https://laguin.id/api/kie/callback"
